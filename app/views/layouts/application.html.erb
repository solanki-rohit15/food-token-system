<!DOCTYPE html>
<html lang="en">
<head>
  <title><%= content_for(:title) || "FoodToken System" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= yield :head %>
  <link rel="icon" href="/icon.png" type="image/png">
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
</head>

<body class="<%= user_signed_in? ? "app-body role-#{current_user.role}" : "auth-body" %>">

  <% if user_signed_in? %>
    <%= render "shared/navbar" %>
  <% end %>

  <%# Flash messages %>
  <% if notice.present? %>
    <div class="ft-flash ft-flash-success" id="flash-notice">
      <i class="bi bi-check-circle-fill me-2"></i><%= notice %>
      <button type="button" class="ft-flash-close" onclick="this.parentElement.remove()">&times;</button>
    </div>
  <% end %>
  <% if alert.present? %>
    <div class="ft-flash ft-flash-danger" id="flash-alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i><%= alert %>
      <button type="button" class="ft-flash-close" onclick="this.parentElement.remove()">&times;</button>
    </div>
  <% end %>

  <main>
    <%= yield %>
  </main>

  <% if user_signed_in? && current_user.employee? %>
    <%= render "shared/employee_bottom_nav" %>
  <% end %>

</body>
</html>
