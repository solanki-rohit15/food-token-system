<% content_for :title, "Dashboard — CCube Food Token" %>

<div class="ft-page pb-5">
  <%# Hero header %>
  <div class="ft-emp-hero">
    <div class="d-flex align-items-center gap-3">
      <div class="ft-avatar-lg">
        <% if current_user.avatar_url.present? %>
          <img src="<%= current_user.avatar_url %>" class="rounded-circle" width="48" height="48" alt="">
        <% else %>
          <%= current_user.initials %>
        <% end %>
      </div>
      <div>
        <div class="ft-greeting">Good <%= time_of_day_greeting %>, <%= current_user.name.split.first %>!</div>
        <div class="ft-emp-id small">
          <% if current_user.employee_profile&.employee_id.present? %>
            ID: <%= current_user.employee_profile.employee_id %>
          <% else %>
            Employee
          <% end %>
        </div>
      </div>
    </div>
    <div class="ft-time-chip mt-3">
      <i class="bi bi-clock me-1"></i>
      <%= Time.current.strftime("%I:%M %p") %>
      &bull;
      <%= Date.current.strftime("%a, %d %b %Y") %>
    </div>
  </div>

  <%# Today's tokens or CTA %>
  <% if @active_today_tokens.any? %>
    <div class="ft-section px-3 mt-3">
      <div class="d-flex justify-content-between align-items-center mb-2">
        <div class="ft-section-label mb-0">Today's Tokens</div>
        <% remaining = FoodItem::CATEGORIES.keys.map(&:to_s) - @ordered_categories %>
        <% any_open  = remaining.any? { |c| @food_by_cat[c]&.first&.available_now? } %>
        <% if any_open %>
          <%= link_to new_employee_food_selection_path, class: "btn btn-sm ft-btn-primary" do %>
            <i class="bi bi-plus-circle me-1"></i>Add Meal
          <% end %>
        <% end %>
      </div>

      <div class="d-flex flex-column gap-2">
        <% @active_today_tokens.each do |token| %>
          <div class="ft-token-hero-card">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <div>
                <div class="ft-token-number">Token #<%= token.id.to_s.rjust(6, "0") %></div>
                <div class="ft-token-items mt-1 text-muted small">
                  <%= token.summary %>
                </div>
              </div>
              <% if token.active? %>
                <span class="ft-status-badge ft-status-active">
                  <span class="ft-status-dot"></span> Active
                </span>
              <% elsif token.redeemed? %>
                <span class="badge bg-success">Redeemed</span>
              <% else %>
                <span class="badge bg-secondary">Expired</span>
              <% end %>
            </div>
            <div class="ft-token-expiry text-muted small">
              <i class="bi bi-clock me-1"></i>
              Expires at <%= token.expires_at.strftime("%I:%M %p") %>
            </div>
            <%= link_to employee_token_path(token), class: "btn ft-btn-qr w-100 mt-3" do %>
              <i class="bi bi-qr-code me-2"></i>Show QR Code
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

  <% else %>
    <%# All tokens are expired or no tokens yet — show Select Meals CTA %>
    <div class="ft-section px-3 mt-3">
      <div class="ft-section-label">Today's Meal</div>
      <div class="ft-no-token-card">
        <div class="ft-no-token-icon">🍽️</div>
        <% if @expired_today_tokens.any? %>
          <h3 class="ft-no-token-title">Your token has expired</h3>
          <p class="text-muted small">Tokens are valid for <%= Token::TOKEN_EXPIRY_HOURS %> hours from generation. You can generate a new one for remaining open meals.</p>
        <% else %>
          <h3 class="ft-no-token-title">No token yet today</h3>
          <p class="text-muted small">Select your meals to generate a QR token</p>
        <% end %>
        <%= link_to new_employee_food_selection_path, class: "btn cc-btn-primary mt-2" do %>
          <i class="bi bi-plus-circle me-2"></i>Select Meals
        <% end %>
      </div>
    </div>

    <%# Show today's expired tokens as collapsed history (not CTA-blocking) %>
    <% if @expired_today_tokens.any? %>
      <div class="ft-section px-3 mt-3">
        <div class="ft-section-label text-muted">Expired Today</div>
        <div class="d-flex flex-column gap-2">
          <% @expired_today_tokens.each do |token| %>
            <div class="ft-token-hero-card opacity-60">
              <div class="d-flex justify-content-between align-items-start mb-2">
                <div>
                  <div class="ft-token-number">Token #<%= token.id.to_s.rjust(6, "0") %></div>
                  <div class="ft-token-items mt-1 text-muted small">
                    <%= token.summary %>
                  </div>
                </div>
                <span class="badge bg-secondary">Expired</span>
              </div>
              <div class="text-muted small">
                <i class="bi bi-clock me-1"></i>Expired at <%= token.expires_at.strftime("%I:%M %p") %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>

  <%# Meal availability status %>
  <div class="ft-section px-3 mt-3">
    <div class="ft-section-label">Meal Windows</div>
    <div class="row g-2">

      <% FoodItem::CATEGORIES.each do |cat, info| %>
        <% food_item = @food_by_cat[cat]&.first %>
        <% setting   = @meal_settings[cat.to_s] %>

        <% available = food_item&.available_now? %>

        <div class="col-6 col-md-3">
          <div class="ft-card text-center p-3 <%= available ? '' : 'opacity-60' %>">
            
            <div style="font-size:24px"><%= info[:icon] %></div>
            <div class="fw-semibold small mt-1"><%= info[:label] %></div>

            <% if setting %>
              <div class="text-muted ft-fs-11">
                <%= setting.formatted_time_range %>
              </div>
            <% end %>

            <div class="mt-1">
              <% if available %>
                <span class="cc-badge-open">Open</span>
              <% else %>
                <span class="cc-badge-closed">Closed</span>
              <% end %>
            </div>

          </div>
        </div>
      <% end %>

    </div>
  </div>

  <%# Stats %>
  <div class="ft-section px-3 mt-3">
    <div class="ft-section-label">My Stats</div>
    <div class="ft-stats-grid">
      <div class="ft-stat-card">
        <div class="ft-stat-val"><%= @stats[:total_orders] %></div>
        <div class="ft-stat-label">Total Orders</div>
      </div>
      <div class="ft-stat-card">
        <div class="ft-stat-val cc-red"><%= @stats[:this_month] %></div>
        <div class="ft-stat-label">This Month</div>
      </div>
      <div class="ft-stat-card">
        <div class="ft-stat-val text-success"><%= @stats[:redeemed_tokens] %></div>
        <div class="ft-stat-label">Redeemed</div>
      </div>
    </div>
  </div>

  <%# Recent tokens %>
  <% if @recent_tokens.any? %>
    <div class="ft-section px-3 mt-3">
      <div class="d-flex justify-content-between align-items-center mb-2">
        <div class="ft-section-label mb-0">Recent Tokens</div>
        <%= link_to "See all", employee_tokens_path, class: "small text-decoration-none cc-red" %>
      </div>
      <div class="d-flex flex-column gap-2">
        <% @recent_tokens.each do |token| %>
          <%= render "employee/tokens/token_row", token: token %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>