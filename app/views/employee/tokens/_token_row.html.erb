<div class="ft-token-row-card">
  <div class="d-flex align-items-center gap-3">
    <div class="ft-token-row-icon">
      <% if token.fully_redeemed? %>
        <i class="bi bi-check-circle-fill text-success fs-4"></i>
      <% elsif token.partially_redeemed? %>
        <i class="bi bi-circle-half text-info fs-4"></i>
      <% elsif token.expired? %>
        <i class="bi bi-x-circle-fill text-danger fs-4"></i>
      <% else %>
        <i class="bi bi-qr-code text-warning fs-4"></i>
      <% end %>
    </div>
    <div class="flex-fill">
      <div class="d-flex justify-content-between align-items-start">
        <div>
          <div class="fw-semibold small">
            <%= token.food_items.map { |fi| "#{fi.icon} #{fi.category_label}" }.join(", ") %>
          </div>
          <div class="text-muted ft-text-xs">
            <%= token.order.date.strftime("%d %b %Y") %> &bull; <%= token.token_number %>
          </div>
        </div>
        <%= token_status_badge(token) %>
      </div>
      <% if token.fully_redeemed? %>
        <div class="text-success small mt-1">
          <i class="bi bi-check me-1"></i>Fully redeemed at <%= token.redeemed_at&.strftime("%I:%M %p") %>
        </div>
      <% elsif token.partially_redeemed? %>
        <div class="text-info small mt-1">
          <i class="bi bi-circle-half me-1"></i>
          <%= token.redeemed_items_count %> of <%= token.order.order_items.count %> items redeemed
        </div>
      <% elsif token.active? && !token.expired_by_time? %>
        <div class="text-warning small mt-1">
          <i class="bi bi-clock me-1"></i>Expires at <%= token.expires_at.strftime("%I:%M %p") %>
        </div>
      <% end %>
    </div>
    <%= link_to employee_token_path(token), class: "btn btn-sm btn-outline-secondary" do %>
      <i class="bi bi-chevron-right"></i>
    <% end %>
  </div>
</div>
