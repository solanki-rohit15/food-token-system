<% content_for :title, "My Tokens — FoodToken" %>

<div class="ft-page pb-5">
  <div class="ft-page-header px-3 py-3">
    <h2 class="ft-page-title mb-1">My Tokens</h2>
    <p class="text-muted small mb-0">Your complete food token history</p>
  </div>

  <%# Active token banner — only shown when token is still redeemable %>
  <% if @active_token %>
    <div class="px-3 mb-3">
      <div class="alert alert-success d-flex align-items-center gap-3 py-3">
        <i class="bi bi-qr-code fs-3"></i>
        <div class="flex-fill">
          <div class="fw-bold">Active Token Today</div>
          <div class="small">Token #<%= @active_token.token_number %> &middot; Valid until <%= @active_token.expires_at.strftime("%I:%M %p") %></div>
        </div>
        <%= link_to "Show QR", employee_token_path(@active_token), class: "btn btn-success btn-sm" %>
      </div>
    </div>
  <% end %>

  <div class="px-3">
    <% if @tokens.any? %>
      <div class="d-flex flex-column gap-2">
        <% @tokens.each do |token| %>
          <%= render "token_row", token: token %>
        <% end %>
      </div>
      <% if @tokens.respond_to?(:total_pages) && @tokens.total_pages > 1 %>
        <div class="d-flex justify-content-center mt-3"><%= paginate @tokens %></div>
      <% end %>
    <% else %>
      <div class="text-center py-5">
        <div class="fs-1">🎫</div>
        <h4 class="text-muted mt-2">No tokens yet</h4>
        <p class="text-muted small">Select your meals to generate a QR token.</p>
        <%= link_to new_employee_food_selection_path, class: "btn ft-btn-primary mt-2" do %>
          <i class="bi bi-plus-circle me-2"></i>Select Meals
        <% end %>
      </div>
    <% end %>
  </div>
</div>
