<% content_for :title, "Token ##{@token.token_number} — FoodToken" %>

<div class="ft-page pb-5">
  <div class="px-3 py-3 d-flex align-items-center gap-2">
    <%= link_to employee_tokens_path, class: "btn btn-sm btn-outline-secondary" do %>
      <i class="bi bi-arrow-left"></i> Back
    <% end %>
    <h2 class="ft-page-title mb-0">Your Food Token</h2>
  </div>

  <div class="px-3">
    <div class="row g-3 justify-content-center">
      <div class="col-md-6 col-lg-5">
        <div class="ft-token-card text-center p-4">

          <!-- STATUS -->
          <div class="mb-3">
            <%= token_status_badge(@token) %>
          </div>

          <!-- QR SECTION -->
          <div class="ft-qr-wrapper mb-3">

            <% if @token.active? && !@token.expired_by_time? %>

              <!-- CATEGORY BUTTONS -->
              <div class="d-flex flex-wrap justify-content-center gap-2 mb-3">
                <% @order&.order_items&.each_with_index do |item, index| %>
                  <button 
                    class="btn btn-sm btn-outline-primary qr-btn"
                    data-target="qr-<%= index %>">
                    <%= item.food_item.icon %> <%= item.food_item.category_label %>
                  </button>
                <% end %>
              </div>

              <!-- QR DISPLAY -->
              <div>
                <% @order&.order_items&.each_with_index do |item, index| %>
                  <div class="qr-box" id="qr-<%= index %>" style="<%= index == 0 ? '' : 'display:none;' %>">

                    <div class="ft-qr-label mb-2">
                      <%= item.food_item.icon %> <%= item.food_item.category_label %>
                    </div>

                    <div class="ft-qr-img mb-2">
                      <%= raw item.qr_svg %>
                    </div>

                    <div class="ft-qr-code-text">
                      Code: <%= item.item_code %>
                    </div>

                  </div>
                <% end %>
              </div>

            <% elsif @token.redeemed? %>

              <div class="d-flex flex-column align-items-center text-success py-4">
                <i class="bi bi-check-circle-fill" style="font-size:64px"></i>
                <div class="mt-2 fw-bold">Fully Redeemed</div>
              </div>

            <% else %>

              <div class="d-flex flex-column align-items-center text-danger py-4">
                <i class="bi bi-x-circle-fill" style="font-size:64px"></i>
                <div class="mt-2 fw-bold">Expired</div>
              </div>

            <% end %>

          </div>

          <!-- SELECTED ITEMS -->
          <div class="d-flex flex-wrap justify-content-center gap-2 mb-3">
            <% @order&.food_items&.each do |fi| %>
              <span class="badge bg-light border text-dark">
                <%= fi.icon %> <%= fi.category_label %>
              </span>
            <% end %>
          </div>

          <!-- 🔥 REDEMPTION REQUESTS -->
          <% if @requests.present? %>
            <% @requests.each do |req| %>
              <div class="alert alert-warning text-start">

                <strong>
                  <%= req.vendor.name %> wants to redeem 
                  <%= req.order_item.food_item.category_label %>
                </strong>

                <% if req.pending? %>
                  <div class="mt-2 d-flex gap-2">

                    <%= button_to "Approve",
                        approve_employee_redemption_request_path(req),
                        method: :post,
                        class: "btn btn-success btn-sm" %>

                    <%= button_to "Reject",
                        reject_employee_redemption_request_path(req),
                        method: :post,
                        class: "btn btn-danger btn-sm" %>

                  </div>
                <% else %>
                  <div class="mt-2">
                    Status: <strong><%= req.status.capitalize %></strong>
                  </div>
                <% end %>

              </div>
            <% end %>
          <% end %>

          <!-- STATUS INFO -->
          <% if @token.active? && !@token.expired_by_time? %>
            <div class="alert alert-info alert-sm py-2 mb-3">
              <i class="bi bi-clock me-1"></i>
              Valid until 
              <strong>
                <%= @token.expires_at&.strftime("%I:%M %p") || "N/A" %>
              </strong>
            </div>
          <% elsif @token.redeemed? %>
            <div class="alert alert-success alert-sm py-2 mb-3">
              <i class="bi bi-check-circle-fill me-1"></i>
              Redeemed at 
              <strong>
                <%= @token.redeemed_at&.strftime("%I:%M %p") %>
              </strong>
            </div>
          <% end %>

          <!-- DETAILS -->
          <table class="table table-sm text-start ft-table-sm">
            <tr>
              <td class="text-muted">Date</td>
              <td class="fw-semibold">
                <%= @order&.date&.strftime("%d %b %Y") || "-" %>
              </td>
            </tr>
            <tr>
              <td class="text-muted">Employee</td>
              <td class="fw-semibold"><%= current_user.name %></td>
            </tr>
          </table>

        </div>
      </div>
    </div>
  </div>
</div>

<!-- QR SWITCH SCRIPT -->
<script>
document.addEventListener("DOMContentLoaded", () => {
  document.querySelectorAll(".qr-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      const target = btn.dataset.target;

      document.querySelectorAll(".qr-box").forEach(box => {
        box.style.display = "none";
      });

      const el = document.getElementById(target);
      if (el) el.style.display = "block";
    });
  });
});
</script>

<!-- AUTO REFRESH -->
<% if @token.active? && !@token.expired_by_time? %>
<script>
setInterval(() => {
  fetch('<%= status_employee_token_path(@token) %>', {
    headers: { 'Accept': 'application/json' }
  })
  .then(r => r.json())
  .then(data => {
    if (data.redeemed || data.expired) location.reload();
  })
  .catch(() => {});
}, 5000);
</script>
<% end %>