<nav class="navbar navbar-expand-lg cc-navbar">
  <div class="container-fluid px-3">

    <%# CCube Logo + Brand %>
    <a class="navbar-brand cc-navbar-brand" href="<%= current_user.dashboard_path %>">
      <%= image_tag "ccube_logo.webp", alt: "CCube", height: "34", class: "cc-logo-img" %>
      <span class="cc-brand-sep d-none d-sm-inline">|</span>
      <span class="cc-brand-sub d-none d-sm-inline">Food Token</span>
    </a>

    <%# Hamburger for mobile %>
    <button class="navbar-toggler cc-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="mainNav">
      <%# Nav links by role %>
      <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center gap-1 me-auto ms-lg-4 mt-2 mt-lg-0">
        <% if current_user.employee? %>
          <%= nav_link "Dashboard",    employee_root_path,               "bi-house-fill" %>
          <%= nav_link "My Token",     employee_tokens_path,             "bi-qr-code" %>
          <%= nav_link "Select Meals", new_employee_food_selection_path, "bi-plus-circle" %>

        <% elsif current_user.vendor? %>
          <%= nav_link "Dashboard",  vendor_root_path,   "bi-speedometer2" %>
          <%= nav_link "All Tokens", vendor_tokens_path, "bi-list-check" %>
          <%= nav_link "Scan QR",    vendor_scan_path,   "bi-qr-code-scan" %>

        <% elsif current_user.admin? %>
          <%= nav_link "Dashboard",  admin_root_path,          "bi-speedometer2" %>
          <%= nav_link "Users",      admin_users_path,         "bi-people" %>
          <%= nav_link "Food Items", admin_food_items_path,    "bi-grid" %>
          <%= nav_link "Tokens",     admin_tokens_path,        "bi-ticket-perforated" %>
          <%= nav_link "Reports",    admin_reports_path,       "bi-bar-chart" %>
          <%= nav_link "Timings",    admin_meal_settings_path, "bi-clock" %>
        <% end %>
      </div>

      <%# User info + Logout %>
      <div class="d-flex align-items-center gap-2 mt-2 mt-lg-0 mb-2 mb-lg-0">
        <div class="cc-user-info d-flex align-items-center gap-2">
          <% if current_user.google_avatar_url.present? %>
            <img src="<%= current_user.google_avatar_url %>" class="cc-avatar rounded-circle" width="30" height="30" alt="">
          <% else %>
            <div class="cc-avatar-initials"><%= current_user.initials %></div>
          <% end %>
          <div class="d-none d-lg-block">
            <div class="cc-user-name"><%= current_user.name.split.first %></div>
            <div class="cc-user-role"><%= current_user.role.capitalize %></div>
          </div>
        </div>

        <%# Logout button — prominently visible for ALL roles %>
        <%= button_to destroy_user_session_path,
              method: :delete,
              class: "btn cc-btn-logout",
              form: { data: { turbo: false } } do %>
          <i class="bi bi-box-arrow-right me-1"></i>
          <span class="d-none d-sm-inline">Logout</span>
        <% end %>
      </div>
    </div>

  </div>
</nav>
