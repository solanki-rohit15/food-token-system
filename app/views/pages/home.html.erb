<% content_for :title, "FoodToken — Workplace Cafeteria System" %>

<div class="auth-body" style="min-height:100vh;">
  <div class="auth-main" style="max-width:460px;width:100%;padding:24px;">
    <div class="ft-auth-card">
      <div class="ft-auth-header">
        <div class="ft-auth-logo">🍽️</div>
        <h1 class="ft-auth-title">FoodToken</h1>
        <p class="ft-auth-sub">Workplace Cafeteria Management System</p>
      </div>

      <div class="d-flex flex-column gap-3">
        <%= link_to new_user_session_path, class: "btn ft-btn-primary w-100 py-3" do %>
          <i class="bi bi-box-arrow-in-right me-2"></i>Sign In with Password
        <% end %>

        <%= link_to users_new_otp_path, class: "btn ft-btn-outline w-100 py-3" do %>
          <i class="bi bi-envelope me-2"></i>Sign In with Email OTP
        <% end %>

        <div class="ft-divider"><span>or</span></div>

        <%= button_to user_google_oauth2_omniauth_authorize_path, method: :post,
              form: { data: { turbo: false } },
              class: "btn ft-btn-google w-100 py-3" do %>
          <svg width="18" height="18" viewBox="0 0 18 18" class="me-2">
            <path fill="#4285F4" d="M16.51 8H8.98v3h4.3c-.18 1-.74 1.48-1.6 2.04v2.01h2.6a7.8 7.8 0 0 0 2.38-5.88c0-.57-.05-.66-.15-1.18z"/>
            <path fill="#34A853" d="M8.98 17c2.16 0 3.97-.72 5.3-1.94l-2.6-2a4.8 4.8 0 0 1-7.18-2.54H1.83v2.07A8 8 0 0 0 8.98 17z"/>
            <path fill="#FBBC05" d="M4.5 10.52a4.8 4.8 0 0 1 0-3.04V5.41H1.83a8 8 0 0 0 0 7.18l2.67-2.07z"/>
            <path fill="#EA4335" d="M8.98 4.18c1.17 0 2.23.4 3.06 1.2l2.3-2.3A8 8 0 0 0 1.83 5.4L4.5 7.49a4.77 4.77 0 0 1 4.48-3.3z"/>
          </svg>
          Sign in with Google
        <% end %>
      </div>

      <div class="ft-auth-footer mt-4">
        <p class="text-muted" style="font-size:12px;">
          <i class="bi bi-shield-lock me-1"></i>Secure · Role-based · Location-verified
        </p>
      </div>
    </div>
  </div>
</div>
