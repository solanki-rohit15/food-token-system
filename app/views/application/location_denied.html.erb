<div class="d-flex align-items-center justify-content-center min-vh-100 bg-light p-3">
  <div class="card shadow border-0 rounded-4" style="max-width: 400px; width: 100%;">
    <div class="card-body p-4 text-center">
      <div class="mx-auto d-flex align-items-center justify-content-center rounded-circle bg-danger-subtle text-danger mb-4" style="width: 60px; height: 60px;">
        <i class="bi bi-geo-alt-fill fs-2"></i>
      </div>
      <h3 class="h5 fw-bold text-dark">Location Access Required</h3>
      <p class="text-secondary small mt-2">
        <%= message %>
      </p>

      <div class="d-grid gap-2 mt-4">
        <a href="javascript:location.reload()" class="btn btn-primary fw-semibold">
          <i class="bi bi-arrow-clockwise me-1"></i> Try Again
        </a>

        <%= link_to destroy_user_session_path, method: :delete, class: "btn btn-outline-secondary fw-semibold" do %>
          <i class="bi bi-box-arrow-right me-1"></i> Sign Out
        <% end %>
      </div>

      <div class="mt-4 text-start bg-light rounded p-3 small text-muted border">
        <p class="fw-semibold mb-2 text-dark">If you're having location issues:</p>
        <ul class="mb-0 ps-3">
          <li>Enable GPS on your device</li>
          <li>Check browser permission for location</li>
          <li>Ensure you're within office premises</li>
        </ul>
      </div>
    </div>
  </div>
</div>
