<% content_for :title, "Sign In — CCube Food Token" %>

<div class="ft-auth-card">
  <div class="ft-auth-header">
    <%= image_tag "ccube_logo.webp", alt: "CCube", class: "cc-auth-logo" %>
    <h1 class="ft-auth-title">Welcome Back</h1>
    <p class="ft-auth-sub">Sign in to your cafeteria account</p>
  </div>

  <%# Google login — employees %>
  <div class="mb-4">
    <%= button_to user_google_oauth2_omniauth_authorize_path,
          method: :post,
          form: { data: { turbo: false } },
          class: "btn ft-btn-google w-100" do %>
      <svg width="18" height="18" viewBox="0 0 18 18" class="me-2" style="flex-shrink:0">
        <path fill="#4285F4" d="M16.51 8H8.98v3h4.3c-.18 1-.74 1.48-1.6 2.04v2.01h2.6a7.8 7.8 0 0 0 2.38-5.88c0-.57-.05-.66-.15-1.18z"/>
        <path fill="#34A853" d="M8.98 17c2.16 0 3.97-.72 5.3-1.94l-2.6-2a4.8 4.8 0 0 1-7.18-2.54H1.83v2.07A8 8 0 0 0 8.98 17z"/>
        <path fill="#FBBC05" d="M4.5 10.52a4.8 4.8 0 0 1 0-3.04V5.41H1.83a8 8 0 0 0 0 7.18l2.67-2.07z"/>
        <path fill="#EA4335" d="M8.98 4.18c1.17 0 2.23.4 3.06 1.2l2.3-2.3A8 8 0 0 0 1.83 5.4L4.5 7.49a4.77 4.77 0 0 1 4.48-3.3z"/>
      </svg>
      Sign in with Google
    <% end %>
    <p class="text-muted text-center mt-1" style="font-size:11px;">For employees — company Google account</p>
  </div>

  <div class="ft-divider"><span>or sign in with email</span></div>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    <% if resource.errors.any? %>
      <div class="alert alert-danger alert-sm mb-3 d-flex align-items-center gap-2">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <%= resource.errors.full_messages.first %>
      </div>
    <% end %>

    <div class="mb-3">
      <label class="form-label ft-label">Email</label>
      <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "form-control ft-input", placeholder: "you@company.com" %>
    </div>

    <div class="mb-3">
      <label class="form-label ft-label">Password</label>
      <%= f.password_field :password, autocomplete: "current-password",
            class: "form-control ft-input", placeholder: "Your password" %>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
      <%= link_to "Forgot password?", new_user_password_path, class: "text-muted small text-decoration-none" %>
    </div>

    <%= f.submit "Sign In", class: "btn cc-btn-primary w-100 mb-3" %>
  <% end %>

  <div class="text-center">
    <p class="text-muted small mb-2">First time? Login via OTP</p> 
    <%= link_to users_new_otp_path, class: "btn cc-btn-outline w-100" do %>
      <i class="bi bi-envelope me-2"></i>Email OTP Login
    <% end %>
  </div>
</div>
