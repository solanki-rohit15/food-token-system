<% content_for :title, "Meal Timings — Admin" %>
<div class="ft-page pb-4">
  <div class="ft-page-header px-3 py-3">
    <h2 class="ft-page-title mb-0">Meal Time Slots</h2>
    <p class="text-muted small mb-0">Configure when each meal is available for selection</p>
  </div>
  <div class="px-3">
    <div class="ft-info-banner mb-3">
      <i class="bi bi-info-circle-fill text-primary me-2"></i>
      <span class="small">Changes take effect immediately. Employees outside the time window cannot select that meal.</span>
    </div>

    <%= form_tag admin_meal_settings_path, method: :patch do %>
      <% @settings.each do |setting| %>
        <% info = FoodItem::CATEGORIES[setting.meal_type.to_s] || {} %>
        <div class="ft-vendor-card mb-3">
          <div class="d-flex align-items-center gap-2 mb-3">
            <span style="font-size:24px;"><%= info[:icon] %></span>
            <h6 class="mb-0 fw-semibold"><%= info[:label] || setting.label %></h6>
          </div>
          <div class="row g-3">
            <div class="col-6">
              <label class="form-label ft-label">Start Time</label>
              <input type="time" name="meal_settings[<%= setting.meal_type %>][start_time]"
                     value="<%= setting.start_time %>" class="form-control ft-input">
            </div>
            <div class="col-6">
              <label class="form-label ft-label">End Time</label>
              <input type="time" name="meal_settings[<%= setting.meal_type %>][end_time]"
                     value="<%= setting.end_time %>" class="form-control ft-input">
            </div>
          </div>
          <div class="mt-2">
            <% if setting.available_now? %>
              <span class="badge bg-success-subtle text-success border border-success-subtle">
                <i class="bi bi-circle-fill me-1" style="font-size:6px;"></i>Currently Available
              </span>
            <% else %>
              <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">
                Currently Closed
              </span>
            <% end %>
          </div>
        </div>
      <% end %>
      <button type="submit" class="btn ft-btn-primary w-100">
        <i class="bi bi-save me-2"></i>Save Time Slots
      </button>
    <% end %>
  </div>
</div>
