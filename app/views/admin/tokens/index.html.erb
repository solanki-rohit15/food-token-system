<% content_for :title, "Tokens — Admin" %>

<div class="ft-page pb-5">
  <div class="ft-page-header px-3 py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
      <h2 class="ft-page-title mb-0">Token Monitor</h2>
      <p class="text-muted small mb-0"><%= @date.strftime("%A, %d %B %Y") %> &bull; <%= @tokens.total_count %> records</p>
    </div>
    <%= link_to export_admin_reports_path(date: @date), class: "btn btn-sm btn-outline-success" do %>
      <i class="bi bi-download me-1"></i>Export CSV
    <% end %>
  </div>

  <div class="px-3 mb-3">
    <%= form_tag admin_tokens_path, method: :get, class: "row g-2 align-items-center js-pjax-form" do %>
      <div class="col-6 col-md-auto">
        <input type="date" name="date" value="<%= @date %>" max="<%= Date.current %>" class="form-control form-control-sm ft-input">
      </div>
      <div class="col-6 col-md-auto">
        <select name="status" class="form-select form-select-sm ft-input">
          <option value="">All Status</option>
          <option value="active"   <%= "selected" if params[:status]=="active"   %>>Active</option>
          <option value="redeemed" <%= "selected" if params[:status]=="redeemed" %>>Redeemed</option>
          <option value="expired"  <%= "selected" if params[:status]=="expired"  %>>Expired</option>
        </select>
      </div>
      <div class="col-12 col-md-auto flex-grow-1">
        <input type="text" name="search" value="<%= params[:search] %>" class="form-control form-control-sm ft-input" placeholder="Search employee...">
      </div>
      <div class="col-auto">
        <button type="submit" class="btn btn-sm ft-btn-primary btn-fixed-sm">
          <i class="bi bi-search me-1"></i>Filter
        </button>
      </div>
      <div class="col-auto">
        <%= link_to "Today", admin_tokens_path, class: "btn btn-sm btn-outline-secondary js-pjax-link btn-fixed-sm" %>
      </div>
    <% end %>
  </div>

  <div class="px-3">
    <div class="table-responsive">
      <table class="table ft-table align-middle">
        <thead class="table-light">
          <tr>
            <th>Employee</th><th>Items</th><th>Token</th>
            <th>Created</th><th>Status</th><th>Redeemed At</th>
          </tr>
        </thead>
        <tbody>
          <% @tokens.each do |token| %>
            <tr>
              <td>
                <div class="d-flex align-items-center gap-2">
                  <div class="ft-avatar-sm"><%= token.user.initials %></div>
                  <div>
                    <div class="fw-semibold small"><%= token.user.name %></div>
                    <div class="text-muted" style="font-size:11px"><%= token.user.email %></div>
                  </div>
                </div>
              </td>

              <td class="small"><%= token.summary %></td>
              <td><span class="badge bg-light border text-dark font-monospace">#<%= token.id.to_s.rjust(6,"0") %></span></td>
              <td class="small text-muted"><%= token.created_at.strftime("%I:%M %p") %></td>
              <td><%= token_status_badge(token) %></td>
              <td class="small text-muted"><%= token.redeemed_at&.strftime("%I:%M %p") || "—" %></td>
            </tr>
          <% end %>
          <% if @tokens.empty? %>
            <tr><td colspan="7" class="text-center text-muted py-4">No tokens found.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <% if @tokens.respond_to?(:total_pages) && @tokens.total_pages > 1 %>
      <div class="d-flex justify-content-center mt-3"><%= paginate @tokens %></div>
    <% end %>
  </div>
</div>
