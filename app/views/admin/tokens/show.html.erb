<% content_for :title, "Token #{@token.token_number} — Admin" %>

<div class="ft-page pb-5">
  <div class="px-3 py-3 d-flex align-items-center gap-2">
    <%= link_to admin_tokens_path, class: "btn btn-sm btn-outline-secondary" do %>
      <i class="bi bi-arrow-left"></i>
    <% end %>
    <h2 class="ft-page-title mb-0"><%= @token.token_number %></h2>
    <%= token_status_badge(@token) %>
  </div>

  <div class="px-3">
    <div class="row g-3">
      <div class="col-md-4">
        <div class="ft-vendor-card text-center">
          <p class="ft-section-label">Employee</p>
          <div class="ft-avatar-xl mx-auto mb-2"><%= @employee.initials %></div>
          <div class="fw-bold"><%= @employee.name %></div>
          <div class="text-muted small"><%= @employee.email %></div>
          <hr>
          <div class="d-flex justify-content-between ft-meta-row small">
            <span class="text-muted">Date</span>
            <span><%= @token.order.date.strftime("%d %b %Y") %></span>
          </div>
          <div class="d-flex justify-content-between ft-meta-row small">
            <span class="text-muted">Created</span>
            <span><%= @token.created_at.strftime("%I:%M %p") %></span>
          </div>
          <div class="d-flex justify-content-between ft-meta-row small">
            <span class="text-muted">Expires</span>
            <span><%= @token.expires_at.strftime("%I:%M %p") %></span>
          </div>
          <% if @token.redeemed? %>
            <div class="d-flex justify-content-between ft-meta-row small text-success">
              <span>Redeemed</span>
              <span><%= @token.redeemed_at.strftime("%I:%M %p") %></span>
            </div>
          <% end %>
        </div>
      </div>

      <div class="col-md-8">
        <div class="ft-section-label mb-2">Meal Item Details</div>
        <% item = @token.order_item %>
        <div class="card mb-3 <%= item.redeemed? ? 'border-success' : 'border-light' %>">
          <div class="card-header d-flex justify-content-between align-items-center py-2">
            <span class="fw-semibold">
              <%= item.food_item.icon %> <%= item.food_item.category_label %>
            </span>
            <%= order_item_badge(item) %>
          </div>
          <div class="card-body py-2 px-3">
            <div class="text-muted ft-text-xs font-monospace mb-2"><%= item.item_code %></div>
            <% if item.redeemed? %>
              <div class="text-success small">
                Redeemed by <%= item.redeemed_by&.name || "unknown" %> at
                <%= item.redeemed_at.strftime("%I:%M %p") %>
              </div>
            <% end %>
            <% reqs = item.redemption_requests.includes(:vendor).order(created_at: :desc) %>
            <% if reqs.any? %>
              <div class="mt-2">
                <div class="ft-text-xs text-muted fw-semibold mb-1">Request History</div>
                <% reqs.each do |req| %>
                  <div class="d-flex gap-2 align-items-center ft-text-xs text-muted mb-1">
                    <span class="badge bg-<%= req.approved? ? 'success' : req.rejected? ? 'danger' : 'warning text-dark' %>">
                      <%= req.status.capitalize %>
                    </span>
                    <span><%= req.vendor.name %></span>
                    <span><%= req.created_at.strftime("%I:%M %p") %></span>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
