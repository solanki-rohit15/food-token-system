<% content_for :title, "Location Settings — Admin" %>

<div class="cc-page pb-5">
  <div class="cc-page-header px-3 py-3">
    <h2 class="cc-page-title mb-1">Location Access Settings</h2>
    <p class="text-muted small mb-0">
      Control where employees can access the system.
      <strong>In development, restrictions are always bypassed.</strong>
    </p>
  </div>

  <div class="px-3 mt-3">
    <%# Warning about location causing logout %>
    <div class="alert alert-info d-flex gap-2 mb-3">
      <i class="bi bi-shield-check fs-5 mt-1"></i>
      <div>
        <strong>Safe Mode:</strong> Location restrictions only show a warning — users are
        <em>never</em> automatically logged out. Enable only when users are in-office.
      </div>
    </div>

    <%= form_tag admin_location_settings_path, method: :patch do %>
      <div class="row g-3">
        <%# IP restriction %>
        <div class="col-md-6">
          <div class="ft-card h-100">
            <h5 class="fw-bold mb-3">
              <i class="bi bi-hdd-network me-2 cc-red"></i>IP-Based Restriction
            </h5>
            <div class="form-check form-switch mb-3">
              <input type="hidden" name="location_setting[ip][enabled]" value="0">
              <input class="form-check-input" type="checkbox"
                     name="location_setting[ip][enabled]" value="1"
                     id="ip-enabled"
                     <%= @ip_setting.enabled? ? "checked" : "" %>>
              <label class="form-check-label fw-semibold" for="ip-enabled">
                Enable IP Restriction
              </label>
            </div>
            <div class="mb-2">
              <label class="form-label ft-label">Allowed IP Range (CIDR)</label>
              <input type="text"
                     name="location_setting[ip][ip_range]"
                     value="<%= @ip_setting.ip_range.presence || '192.168.1.0/24' %>"
                     class="form-control ft-input font-monospace"
                     placeholder="192.168.1.0/24">
              <div class="form-text small">e.g. 192.168.1.0/24 or 10.0.0.0/8</div>
            </div>
          </div>
        </div>

        <%# GPS restriction %>
        <div class="col-md-6">
          <div class="ft-card h-100">
            <h5 class="fw-bold mb-3">
              <i class="bi bi-geo-alt me-2 cc-red"></i>GPS-Based Restriction
            </h5>
            <div class="form-check form-switch mb-3">
              <input type="hidden" name="location_setting[gps][enabled]" value="0">
              <input class="form-check-input" type="checkbox"
                     name="location_setting[gps][enabled]" value="1"
                     id="gps-enabled"
                     <%= @gps_setting.enabled? ? "checked" : "" %>>
              <label class="form-check-label fw-semibold" for="gps-enabled">
                Enable GPS Restriction
              </label>
            </div>
            <div class="row g-2 mb-2">
              <div class="col-6">
                <label class="form-label ft-label">Latitude</label>
                <input type="number" step="0.000001"
                       name="location_setting[gps][latitude]"
                       value="<%= @gps_setting.latitude %>"
                       class="form-control ft-input" placeholder="22.7196">
              </div>
              <div class="col-6">
                <label class="form-label ft-label">Longitude</label>
                <input type="number" step="0.000001"
                       name="location_setting[gps][longitude]"
                       value="<%= @gps_setting.longitude %>"
                       class="form-control ft-input" placeholder="75.8577">
              </div>
            </div>
            <div>
              <label class="form-label ft-label">Radius (metres)</label>
              <input type="number"
                     name="location_setting[gps][radius_meters]"
                     value="<%= @gps_setting.radius_meters.presence || 100 %>"
                     class="form-control ft-input" min="10" max="5000">
            </div>
          </div>
        </div>
      </div>

      <div class="mt-4">
        <button type="submit" class="btn cc-btn-primary px-5">
          <i class="bi bi-save me-2"></i>Save Settings
        </button>
      </div>
    <% end %>
  </div>
</div>
