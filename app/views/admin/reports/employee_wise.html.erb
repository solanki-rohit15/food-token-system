<% content_for :title, "Employee-wise Report — Admin" %>
<div class="ft-page pb-5">
  <div class="px-3 py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
      <h2 class="ft-page-title mb-0">Employee-wise Report</h2>
      <p class="text-muted small mb-0"><%= @date.strftime("%d %B %Y") %></p>
    </div>
    <div class="d-flex gap-2 align-items-center">
      <%= form_tag employee_wise_admin_reports_path, method: :get, class: "d-flex gap-2 js-pjax-form" do %>
        <input type="date" name="date" value="<%= @date %>" max="<%= Date.current %>"
               class="form-control form-control-sm ft-input ft-w-160 js-auto-submit">
      <% end %>
      <%= link_to admin_reports_path, class: "btn btn-sm btn-outline-secondary js-pjax-link" do %><i class="bi bi-arrow-left me-1"></i>Back<% end %>
    </div>
  </div>

  <div class="px-3">
    <div class="table-responsive">
      <table class="table ft-table align-middle">
        <thead class="table-light">
          <tr><th>Employee</th><th>Meal Item</th><th>Token Status</th><th>Time</th></tr>
        </thead>
        <tbody>
          <% @date_tokens.each do |token| %>
            <% user = token.user %>
            <tr>
              <td>
                <div class="d-flex align-items-center gap-2">
                  <div class="ft-avatar-sm"><%= user.initials %></div>
                  <div>
                    <div class="fw-semibold small"><%= user.name %></div>
                    <div class="text-muted" style="font-size:11px"><%= user.email %></div>
                  </div>
                </div>
              </td>
              <td class="small"><%= token.summary %></td>
              <td><%= token_status_badge(token) %></td>
              <td class="small text-muted"><%= token.created_at.strftime("%I:%M %p") %></td>
            </tr>
          <% end %>
          <% if @date_tokens.empty? %>
            <tr><td colspan="4" class="text-center text-muted py-4">No tokens on this date.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
