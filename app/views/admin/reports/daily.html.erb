<% content_for :title, "Daily Report — Admin" %>
<div class="ft-page pb-5">
  <div class="px-3 py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
      <h2 class="ft-page-title mb-0">Daily Report</h2>
      <p class="text-muted small mb-0"><%= @date.strftime("%A, %d %B %Y") %></p>
    </div>
    <div class="d-flex gap-2 align-items-center">
      <%= form_tag daily_admin_reports_path, method: :get, class: "d-flex gap-2 js-pjax-form" do %>
        <input type="date" name="date" value="<%= @date %>" max="<%= Date.current %>"
               class="form-control form-control-sm ft-input" style="width:160px" onchange="$(this.form).trigger('submit')">
      <% end %>
      <%= link_to admin_reports_path, class: "btn btn-sm btn-outline-secondary js-pjax-link" do %>
        <i class="bi bi-arrow-left me-1"></i>Back
      <% end %>
    </div>
  </div>

  <div class="px-3">
    <div class="table-responsive">
      <table class="table ft-table align-middle">
        <thead class="table-light">
          <tr><th>Employee</th><th>Email</th><th>Items</th><th>Token</th><th>Status</th><th>Time</th></tr>
        </thead>
        <tbody>
          <% @orders.each do |order| %>
            <tr>
              <td>
                <div class="d-flex align-items-center gap-2">
                  <div class="ft-avatar-sm"><%= order.user.initials %></div>
                  <div>
                    <div class="fw-semibold small"><%= order.user.name %></div>
                  </div>
                </div>
              </td>
              <td class="small text-muted"><%= order.user.email %></td>
              <td class="small"><%= order.items_label %></td>
              <td><span class="badge bg-light border text-dark font-monospace">#<%= order.token&.id.to_s.rjust(6,"0") %></span></td>
              <td><%= token_status_badge(order.token) %></td>
              <td class="small text-muted"><%= order.created_at.strftime("%I:%M %p") %></td>
            </tr>
          <% end %>
          <% if @orders.empty? %>
            <tr><td colspan="6" class="text-center text-muted py-4">No orders on this date.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
