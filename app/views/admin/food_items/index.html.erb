<% content_for :title, "Food Items — Admin" %>

<div class="ft-page pb-5">
  <div class="ft-page-header px-3 py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
      <h2 class="ft-page-title mb-0">Food Items</h2>
      <p class="text-muted small mb-0">Manage cafeteria categories</p>
    </div>
    <%= link_to new_admin_food_item_path, class: "btn ft-btn-primary btn-sm" do %>
      <i class="bi bi-plus-lg me-1"></i>Add Item
    <% end %>
  </div>

  <div class="px-3">
    <% FoodItem::CATEGORIES.each do |cat, info| %>
      <% items = @food_items.select { |fi| fi.category == cat.to_s } %>
      <% next if items.empty? %>

      <div class="mb-4">
        <!-- Category Header -->
        <div class="d-flex align-items-center gap-2 mb-2">
          <span class="fs-4"><%= info[:icon] %></span>
          <h5 class="mb-0 fw-bold"><%= info[:label] %></h5>
          <span class="badge bg-secondary"><%= items.count %></span>
        </div>

        <!-- Table -->
        <div class="table-responsive">
          <table class="table ft-table align-middle">
            <thead class="table-light">
              <tr>
                <th>Category</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>

            <tbody>
              <% items.each do |item| %>
                <tr>
                  <!-- CATEGORY ONLY -->
                  <td class="fw-semibold">
                    <%= item.icon %> <%= item.category_label %>
                  </td>

                  <!-- STATUS -->
                  <td>
                    <% if item.active? %>
                      <span class="badge bg-success-subtle text-success border border-success-subtle">
                        Active
                      </span>
                    <% else %>
                      <span class="badge bg-secondary-subtle text-secondary border">
                        Inactive
                      </span>
                    <% end %>
                  </td>

                  <!-- ACTIONS -->
                  <td>
                    <div class="d-flex gap-1">
                      <%= link_to "Edit", edit_admin_food_item_path(item),
                            class: "btn btn-sm btn-outline-primary" %>

                      <%= button_to item.active? ? "Deactivate" : "Activate",
                            toggle_active_admin_food_item_path(item),
                            method: :patch,
                            class: "btn btn-sm #{item.active? ? 'btn-outline-warning' : 'btn-outline-success'}" %>

                      <% unless item.order_items.exists? %>
                        <%= button_to "Delete",
                              admin_food_item_path(item),
                              method: :delete,
                              class: "btn btn-sm btn-outline-danger",
                              data: { turbo_confirm: "Delete this item?" } %>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>

          </table>
        </div>
      </div>
    <% end %>

    <% if @food_items.empty? %>
      <div class="text-center py-5 text-muted">
        <div class="fs-1">🍽️</div>
        <p>No food items yet. <%= link_to "Add one", new_admin_food_item_path %>.</p>
      </div>
    <% end %>
  </div>
</div>