<%= form_with model: [:admin, food_item], local: true do |f| %>
  <% if food_item.errors.any? %>
    <div class="alert alert-danger">
      <% food_item.errors.full_messages.each do |msg| %>
        <div><i class="bi bi-exclamation-circle me-2"></i><%= msg %></div>
      <% end %>
    </div>
  <% end %>

  <div class="card ft-card">
    <div class="card-body">

      <div class="mb-3">
        <label class="form-label ft-label">Category *</label>
        <%= f.select :category,
              FoodItem::CATEGORIES.map { |k, v| ["#{v[:icon]} #{v[:label]}", k] },
              { prompt: "Select category" },
              class: "form-select ft-input", required: true %>
      </div>

      <div class="mb-3">
        <div class="form-check form-switch">
          <%= f.hidden_field :active, value: "0" %>
          <%= f.check_box :active, class: "form-check-input", id: "food_item_active" %>
          <%= f.label :active, "Active (visible to employees)", class: "form-check-label" %>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-3 d-flex gap-2">
    <%= f.submit food_item.new_record? ? "Add Food Item" : "Save Changes",
          class: "btn ft-btn-primary px-4" %>
    <%= link_to "Cancel", admin_food_items_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
