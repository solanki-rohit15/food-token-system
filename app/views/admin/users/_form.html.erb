<%= form_with model: [:admin, user], local: true do |f| %>
  <% if user.errors.any? %>
    <div class="alert alert-danger">
      <% user.errors.full_messages.each do |msg| %>
        <div><i class="bi bi-exclamation-circle me-2"></i><%= msg %></div>
      <% end %>
    </div>
  <% end %>

  <div class="card ft-card mb-3">
    <div class="card-header bg-white"><h5 class="mb-0 fw-bold">User Details</h5></div>
    <div class="card-body">
      <div class="mb-3">
        <label class="form-label ft-label">Full Name *</label>
        <%= f.text_field :name, class: "form-control ft-input", required: true %>
      </div>
      <div class="mb-3">
        <label class="form-label ft-label">Email *</label>
        <%= f.email_field :email, class: "form-control ft-input", required: true %>
      </div>
      <div class="mb-3">
        <label class="form-label ft-label">Phone</label>
        <%= f.telephone_field :phone, class: "form-control ft-input", placeholder: "+91…" %>
      </div>
      <div class="mb-3">
        <label class="form-label ft-label">Role *</label>
        <%= f.select :role, [["Employee","employee"],["Vendor","vendor"],["Admin","admin"]],
              {}, class: "form-select ft-input" %>
      </div>

      <% unless user.new_record? %>
        <%# Only show password fields when editing — leave blank to keep existing %>
        <div class="mb-3">
          <label class="form-label ft-label">New Password <span class="text-muted">(leave blank to keep current)</span></label>
          <%= f.password_field :password, class: "form-control ft-input",
                placeholder: "Min. 8 characters", autocomplete: "new-password" %>
        </div>
        <div class="mb-3">
          <label class="form-label ft-label">Confirm New Password</label>
          <%= f.password_field :password_confirmation, class: "form-control ft-input",
                autocomplete: "new-password" %>
        </div>
        <div class="mb-3">
          <div class="form-check form-switch">
            <%= f.hidden_field :active, value: "0" %>
            <%= f.check_box :active, class: "form-check-input" %>
            <%= f.label :active, "Account Active", class: "form-check-label" %>
          </div>
        </div>
      <% end %>

      <% if user.new_record? %>
        <div class="alert alert-info py-2 small">
          <i class="bi bi-info-circle me-1"></i>
          A secure temporary password will be generated and emailed to the user.
          They will be required to change it on first login.
        </div>
      <% end %>
    </div>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit user.new_record? ? "Create User & Send Invite" : "Save Changes",
          class: "btn ft-btn-primary px-4" %>
    <%= link_to "Cancel", admin_users_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
