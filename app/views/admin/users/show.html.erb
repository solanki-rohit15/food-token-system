<% if turbo_frame_request? %>
  <turbo-frame id="user_modal">
    <div class="modal fade" id="userShowModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title d-flex align-items-center gap-2">
              <%= @user.name %>
              <%= role_badge(@user.role) %>
              <span id="user_show_status_badge_<%= @user.id %>">
                <%= @user.active? ? content_tag(:span, "Active", class: "badge bg-success") : content_tag(:span, "Inactive", class: "badge bg-secondary") %>
              </span>
            </h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body bg-light">
            <div class="row g-3">
              <div class="col-md-4">
                <%= render "profile_card", user: @user %>
              </div>
              <div class="col-md-8">
                <%= render "recent_tokens_card", recent_tokens: @recent_tokens %>
              </div>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
            <%= link_to "Edit User", edit_admin_user_path(@user), class: "btn btn-outline-primary", data: { turbo: false } %>
          </div>
        </div>
      </div>
    </div>
    <script>
      (function() {
        var modalEl = document.getElementById('userShowModal');
        var myModal = new bootstrap.Modal(modalEl);
        myModal.show();
        modalEl.addEventListener('hidden.bs.modal', function () {
          document.getElementById('user_modal').innerHTML = '';
        });
      })();
    </script>
  </turbo-frame>
<% else %>
  <% content_for :title, "#{@user.name} — Admin" %>

  <div class="ft-page pb-5">
    <div class="px-3 py-3 d-flex align-items-center justify-content-between flex-wrap gap-2">
      <div class="d-flex align-items-center gap-2">
        <%= link_to admin_users_path, class: "btn btn-sm btn-outline-secondary" do %><i class="bi bi-arrow-left"></i><% end %>
        <h2 class="ft-page-title mb-0"><%= @user.name %></h2>
        <%= role_badge(@user.role) %>
        <span id="user_show_status_badge_<%= @user.id %>">
          <%= @user.active? ? content_tag(:span, "Active", class: "badge bg-success") : content_tag(:span, "Inactive", class: "badge bg-secondary") %>
        </span>
      </div>
      <div class="d-flex gap-2">
        <%= link_to "Edit", edit_admin_user_path(@user), class: "btn btn-sm btn-outline-primary" %>
        <%= button_to @user.active? ? "Deactivate" : "Activate",
              toggle_active_admin_user_path(@user), method: :patch,
              class: "btn btn-sm #{@user.active? ? 'btn-outline-warning' : 'btn-outline-success'} js-user-show-toggle-btn",
              form: {
                class: "d-inline js-fetch-form js-user-show-toggle-form",
                data: { ajax: "true", turbo: "false", user_id: @user.id }
              } %>
        <%= button_to "Resend Invite", resend_invitation_admin_user_path(@user), method: :post,
              class: "btn btn-sm btn-outline-info",
              form: {
                class: "d-inline js-fetch-form js-user-resend-form",
                data: { ajax: "true", turbo: "false", user_id: @user.id }
              } %>
      </div>
    </div>

    <div class="px-3">
      <div class="row g-3">
        <div class="col-md-4">
          <%= render "profile_card", user: @user %>
        </div>
        <div class="col-md-8">
          <%= render "recent_tokens_card", recent_tokens: @recent_tokens %>
        </div>
      </div>
    </div>
  </div>
<% end %>
