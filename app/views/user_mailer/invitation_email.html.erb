<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
      <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="card-header bg-danger bg-gradient text-white text-center py-4 border-0">
          <div class="display-6 fw-bold mb-2">CCube</div>
          <h1 class="h4 fw-bold m-0">Welcome to Food Token!</h1>
        </div>
        
        <div class="card-body p-4 bg-white">
          <p class="text-dark">Hi <strong><%= @user.name %></strong>,</p>
          <p class="text-dark">Your account has been created on the <strong>CCube Food Token System</strong>.</p>

          <div class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill px-3 py-2 mb-3 fs-6">
            <% if @user.employee? %>👤 Employee
            <% elsif @user.vendor? %>🧑‍🍳 Vendor
            <% else %>⚙️ Admin<% end %>
          </div>

          <p class="text-dark"><strong>Your login credentials:</strong></p>

          <div class="bg-light border rounded p-3 my-3 font-monospace">
            <div class="text-uppercase text-secondary fw-bold small">Email</div>
            <div class="fs-5 fw-bold text-danger mt-1"><%= @user.email %></div>
          </div>

          <div class="bg-light border rounded p-3 my-3 font-monospace">
            <div class="text-uppercase text-secondary fw-bold small">Temporary Password</div>
            <div class="fs-5 fw-bold text-danger mt-1"><%= @temp_password %></div>
          </div>

          <p class="text-danger small fw-bold">
            ⚠️ You will be asked to change this password on your first login.
          </p>

          <div class="text-center my-4">
            <a href="<%= @login_url %>" class="btn btn-danger btn-lg px-4 fw-bold rounded-3">🚀 Login Now</a>
          </div>

          <p class="text-secondary small mt-4 mb-0">
            If you did not expect this email, please contact your system administrator immediately.
          </p>
        </div>
        
        <div class="card-footer bg-light text-center py-3 text-secondary small border-top">
          © <%= Date.current.year %> CCube Food Token System. Secure Cafeteria Management.
        </div>
      </div>
    </div>
  </div>
</div>
