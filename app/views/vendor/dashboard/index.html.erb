<% content_for :title, "Vendor Dashboard — FoodToken" %>

<%#
  Meta tags give dashboard.js the initial server-rendered state.
  On AJAX filter changes, dashboard.js updates these values too.
%>
<meta name="dashboard-view"  content="<%= @view_mode %>">
<meta name="dashboard-date"  content="<%= @date&.strftime('%Y-%m-%d') || Date.current.strftime('%Y-%m-%d') %>">
<meta name="dashboard-month" content="<%= @month&.strftime('%Y-%m') || Date.current.strftime('%Y-%m') %>">

<div class="ft-page pb-5" id="vendor-dashboard">

  <%# ── Header ─────────────────────────────────────────────────────── %>
  <div class="ft-vendor-header px-3 pt-3 pb-2">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
      <div>
        <h2 class="ft-page-title mb-0">Vendor Dashboard</h2>
        <p class="text-muted small mb-0" id="dashboard-subtitle">
          <%= @view_mode == "monthly" ? "#{@month&.strftime('%B %Y')} — Monthly Report" : (@date == Date.current ? "Today" : @date&.strftime("%A, %d %B %Y")) %>
        </p>
      </div>

      <div class="d-flex gap-2 align-items-center flex-wrap">
        <%# View mode toggle — AJAX, no page reload %>
        <div class="btn-group btn-group-sm">
          <button id="btn-view-daily"   class="btn ft-dashboard-toggle <%= @view_mode == 'daily'   ? 'btn-primary' : 'btn-outline-secondary' %>">
            Daily
          </button>
          <button id="btn-view-monthly" class="btn ft-dashboard-toggle <%= @view_mode == 'monthly' ? 'btn-primary' : 'btn-outline-secondary' %>">
            Monthly
          </button>
        </div>

        <%# Date controls for daily view %>
        <div id="date-controls" class="d-flex align-items-center gap-1 <%= @view_mode == 'monthly' ? 'd-none' : '' %>">
          <input type="date" id="date-picker"
                 value="<%= @date&.strftime('%Y-%m-%d') || Date.current %>"
                 max="<%= Date.current %>"
                 class="form-control form-control-sm ft-input" style="width:160px">
          <button id="btn-today" class="btn btn-sm btn-outline-secondary ft-dashboard-btn">
            Today
          </button>
        </div>

        <%# Month controls for monthly view %>
        <div id="month-controls" class="d-flex align-items-center gap-1 <%= @view_mode == 'daily' ? 'd-none' : '' %>">
          <input type="month" id="month-picker"
                 value="<%= @month&.strftime('%Y-%m') || Date.current.strftime('%Y-%m') %>"
                 max="<%= Date.current.strftime('%Y-%m') %>"
                 class="form-control form-control-sm ft-input" style="width:160px">
        </div>

        <%# Loading spinner — shown during AJAX fetch %>
        <span id="dashboard-loading" class="d-none">
          <span class="spinner-border spinner-border-sm text-secondary" aria-hidden="true"></span>
        </span>
      </div>
    </div>
  </div>

  <%# ── Daily view ──────────────────────────────────────────────────── %>
  <div id="daily-view" class="<%= @view_mode == 'monthly' ? 'd-none' : '' %>">

    <%# Stats row %>
    <div class="px-3 mt-2">
      <div class="row g-2">
        <div class="col-6 col-md-3">
          <div class="ft-stat-card">
            <div class="ft-stat-val" id="stat-total"><%= @stats&.dig(:total_selected) || 0 %></div>
            <div class="ft-stat-label">Total Tokens</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="ft-stat-card">
            <div class="ft-stat-val text-success" id="stat-redeemed"><%= @stats&.dig(:redeemed) || 0 %></div>
            <div class="ft-stat-label">Redeemed</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="ft-stat-card">
            <div class="ft-stat-val text-warning" id="stat-unredeemed"><%= @stats&.dig(:unredeemed) || 0 %></div>
            <div class="ft-stat-label">Pending</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="ft-stat-card">
            <div class="ft-stat-val text-primary" id="stat-amount"><%= currency(@stats&.dig(:total_amount) || 0) %></div>
            <div class="ft-stat-label">Total Amount</div>
          </div>
        </div>
      </div>
    </div>

    <%# Meal breakdown %>
    <div id="meal-summary-section" class="ft-section px-3 mt-3 <%= @meal_summary&.none? { |_, v| v[:count] > 0 } ? 'd-none' : '' %>">
      <div class="ft-section-label">Meal Breakdown (Redeemed)</div>
      <div class="ft-vendor-card">
        <div class="table-responsive">
          <table class="table table-sm ft-table align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Category</th>
                <th class="text-center">Count</th>
                <th class="text-end">Unit Price</th>
                <th class="text-end">Total</th>
              </tr>
            </thead>
            <tbody id="meal-summary-tbody">
              <% @meal_summary&.each do |_, data| %>
                <% next if data[:count] == 0 %>
                <tr>
                  <td><%= data[:icon] %> <%= data[:label] %></td>
                  <td class="text-center fw-bold"><%= data[:count] %></td>
                  <td class="text-end text-muted"><%= currency(data[:price]) %></td>
                  <td class="text-end fw-bold"><%= currency(data[:amount]) %></td>
                </tr>
              <% end %>
            </tbody>
            <tfoot class="table-light">
              <tr>
                <td colspan="3" class="fw-bold">Grand Total</td>
                <td class="text-end fw-bold text-primary" id="meal-summary-grand-total">
                  <%= currency(@meal_summary&.values&.sum { |v| v[:amount] } || 0) %>
                </td>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>
    </div>

    <%# Recent redemptions %>
    <div id="recent-scans-section" class="ft-section px-3 mt-3 <%= @recent_scans&.any? ? '' : 'd-none' %>">
      <div class="d-flex justify-content-between align-items-center mb-2">
        <div class="ft-section-label mb-0">Recent Redemptions</div>
        <%= link_to "View all", vendor_tokens_path, class: "small text-primary text-decoration-none" %>
      </div>
      <div class="table-responsive">
        <table class="table table-sm ft-table align-middle mb-0">
          <thead class="table-light">
            <tr><th>Employee</th><th>Categories</th><th>Token</th><th>Redeemed At</th></tr>
          </thead>
          <tbody id="recent-scans-tbody">
            <% @recent_scans&.each do |token| %>
              <tr>
                <td>
                  <div class="d-flex align-items-center gap-2">
                    <div class="ft-avatar-sm"><%= token.user.initials %></div>
                    <div>
                      <div class="fw-semibold small"><%= token.user.name %></div>
                      <div class="text-muted" style="font-size:11px"><%= token.user.employee_profile&.department %></div>
                    </div>
                  </div>
                </td>
                <td class="small"><%= token.order.items_label %></td>
                <td><span class="badge bg-success-subtle text-success border border-success-subtle font-monospace"><%= token.token_number %></span></td>
                <td class="small text-muted"><%= token.redeemed_at&.strftime("%I:%M %p") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <%# Empty state %>
    <div id="empty-state" class="px-3 mt-4 text-center <%= @today_tokens&.none? ? '' : 'd-none' %>">
      <div style="font-size:48px">🍽️</div>
      <p class="text-muted">No tokens for <%= @date == Date.current ? "today" : @date&.strftime("%b %d") %> yet.</p>
    </div>

  </div>

  <%# ── Monthly view ────────────────────────────────────────────────── %>
  <div id="monthly-view" class="<%= @view_mode == 'daily' ? 'd-none' : '' %>">

    <%# Monthly summary %>
    <div class="ft-section px-3 mt-3">
      <div class="ft-section-label">Monthly Summary — <span id="monthly-month-label"><%= @month&.strftime("%B %Y") %></span></div>
      <div class="ft-vendor-card">
        <div class="table-responsive">
          <table class="table table-sm ft-table align-middle mb-0">
            <thead class="table-light">
              <tr><th>Category</th><th class="text-center">Count</th><th class="text-end">Unit Price</th><th class="text-end">Total</th></tr>
            </thead>
            <tbody id="monthly-summary-tbody">
              <% @monthly_summary&.each do |_, data| %>
                <% next if data[:count] == 0 %>
                <tr>
                  <td><%= data[:icon] %> <%= data[:label] %></td>
                  <td class="text-center fw-bold"><%= data[:count] %></td>
                  <td class="text-end text-muted"><%= currency(data[:price]) %></td>
                  <td class="text-end fw-bold"><%= currency(data[:amount]) %></td>
                </tr>
              <% end %>
            </tbody>
            <tfoot class="table-light">
              <tr>
                <td colspan="3" class="fw-bold">Grand Total</td>
                <td class="text-end fw-bold text-primary fs-6" id="monthly-grand-total">
                  <%= currency(@monthly_summary&.values&.sum { |v| v[:amount] } || 0) %>
                </td>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>
    </div>

    <%# Daily breakdown %>
    <% if @daily_breakdown&.any? { |d| d[:total] > 0 } %>
      <div class="ft-section px-3 mt-3">
        <div class="ft-section-label">Daily Breakdown</div>
        <div class="ft-vendor-card p-0">
          <div class="table-responsive">
            <table class="table table-sm ft-table align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th>Date</th>
                  <% FoodItem::CATEGORIES.each do |_, info| %>
                    <th class="text-center"><%= info[:icon] %></th>
                  <% end %>
                  <th class="text-end">Day Total</th>
                </tr>
              </thead>
              <tbody id="daily-breakdown-tbody">
                <% @daily_breakdown.each do |day| %>
                  <% next if day[:total] == 0 %>
                  <tr>
                    <td class="small fw-semibold"><%= day[:date].strftime("%d %b") %></td>
                    <% FoodItem::CATEGORIES.each_key do |cat| %>
                      <td class="text-center small"><%= day[:summary][cat]&.dig(:count) || 0 %></td>
                    <% end %>
                    <td class="text-end fw-bold"><%= currency(day[:total]) %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    <% end %>

  </div>

</div>

