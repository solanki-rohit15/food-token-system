<% content_for :title, "Tokens — FoodToken" %>

<div class="ft-page pb-5" id="vendor-tokens-page">
  <div class="ft-page-header px-3 py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
      <h2 class="ft-page-title mb-0">All Tokens</h2>
      <p class="text-muted small mb-0" id="tokens-date-label">
        <%= @date == Date.current ? "Today" : @date.strftime("%A, %d %B %Y") %>
        &bull; <%= @tokens.total_count %> records
      </p>
    </div>

  </div>

  <%# Filter row — all AJAX, no page submit %>
  <div class="px-3 mb-3">
    <div class="d-flex flex-wrap gap-2 align-items-center">
      <input type="date" id="token-date-picker"
             value="<%= @date %>" max="<%= Date.current %>"
             class="form-control form-control-sm ft-input ft-filter-control"
             style="width:150px">
      <select id="token-status-select" class="form-select form-select-sm ft-input ft-filter-control" style="width:140px">
        <option value="">All Status</option>
        <option value="active"   <%= "selected" if params[:status] == "active"   %>>Active</option>
        <option value="redeemed" <%= "selected" if params[:status] == "redeemed" %>>Redeemed</option>
        <option value="expired"  <%= "selected" if params[:status] == "expired"  %>>Expired</option>
      </select>
      <input type="text" id="token-search"
             value="<%= params[:search] %>"
             class="form-control form-control-sm ft-input ft-filter-control"
             placeholder="Name, email or token no."
             style="width:200px">
      <button id="btn-filter-tokens" class="btn btn-sm ft-btn-primary ft-dashboard-btn">
        <i class="bi bi-search me-1"></i>Filter
      </button>
      <button id="btn-today-tokens" class="btn btn-sm btn-outline-secondary ft-dashboard-btn">
        Today
      </button>
    </div>
  </div>

  <div class="px-3">
    <div class="table-responsive">
      <table class="table ft-table align-middle">
        <thead class="table-light">
          <tr>
            <th>Employee</th>
            <th>Categories</th>
            <th>Token No.</th>
            <th>Time</th>
            <th>Status</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody id="tokens-tbody">
          <% @tokens.each do |token| %>
            <tr>
              <td>
                <div class="d-flex align-items-center gap-2">
                  <div class="ft-avatar-sm"><%= token.user.initials %></div>
                  <div>
                    <div class="fw-semibold small"><%= token.user.name %></div>
                  </div>
                </div>
              </td>
              <td class="small"><%= token.order.items_label %></td>
              <td><span class="badge bg-light border text-dark font-monospace"><%= token.token_number %></span></td>
              <td class="small text-muted"><%= token.created_at.strftime("%I:%M %p") %></td>
              <td><%= token_status_badge(token) %></td>
              <td>
                <%= link_to "View", vendor_token_path(token), class: "btn btn-sm btn-outline-secondary ft-dashboard-btn" %>
              </td>
            </tr>
          <% end %>
          <% if @tokens.empty? %>
            <tr>
              <td colspan="6" class="text-center text-muted py-4">
                <div class="fs-1">🎫</div>No tokens found.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @tokens.respond_to?(:total_pages) && @tokens.total_pages > 1 %>
      <div class="d-flex justify-content-center mt-3"><%= paginate @tokens %></div>
    <% end %>
  </div>
</div>

