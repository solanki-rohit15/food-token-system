<% content_for :title, "Token #{@token.token_number} — FoodToken" %>
<% content_for :body_data, "data-token-status-url=\"#{status_vendor_token_path(@token)}\"".html_safe %>

<div class="ft-page pb-5">
  <div class="px-3 py-3 d-flex align-items-center gap-2">
    <%= link_to vendor_tokens_path, class: "btn btn-sm btn-outline-secondary" do %>
      <i class="bi bi-arrow-left"></i>
    <% end %>
    <h2 class="ft-page-title mb-0"><%= @token.token_number %></h2>
    <%= token_status_badge(@token) %>
  </div>

  <div class="px-3">
    <div class="row g-3">
      <div class="col-md-4">
        <div class="ft-vendor-card text-center">
          <p class="ft-section-label">Employee</p>
          <div class="ft-avatar-xl mx-auto mb-2"><%= @employee.initials %></div>
          <div class="fw-bold"><%= @employee.name %></div>
          <div class="text-muted small"><%= @employee.email %></div>
          <hr>
          <div class="d-flex justify-content-between small text-muted">
            <span>Created</span><span><%= @token.created_at.strftime("%I:%M %p") %></span>
          </div>
          <div class="d-flex justify-content-between small text-muted mt-1">
            <span>Expires</span><span><%= @token.expires_at.strftime("%I:%M %p") %></span>
          </div>
          <% if @token.fully_redeemed? %>
            <div class="d-flex justify-content-between small text-success mt-1">
              <span>Fully redeemed</span><span><%= @token.redeemed_at.strftime("%I:%M %p") %></span>
            </div>
          <% end %>
        </div>
      </div>

      <div class="col-md-8">
        <div class="ft-section-label mb-2">Items & Redemption Status</div>
        <% @order_items.each do |item| %>
          <% pending_for_item = @pending_requests.any? { |r| r.order_item_id == item.id } %>
          <div class="card mb-3 <%= item.redeemed? ? 'border-success' : 'border-primary' %>">
            <div class="card-header d-flex align-items-center justify-content-between py-2">
              <span class="fw-semibold"><%= item.food_item.icon %> <%= item.food_item.category_label %></span>
              <% if item.redeemed? %>
                <span class="badge bg-success">✅ <%= item.redeemed_at&.strftime("%I:%M %p") %></span>
              <% elsif pending_for_item %>
                <span class="badge bg-warning text-dark">⏳ Waiting</span>
              <% else %>
                <span class="badge bg-light border text-dark">Not redeemed</span>
              <% end %>
            </div>
            <div class="card-body py-2 px-3">
              <div class="small text-muted font-monospace mb-2"><%= item.item_code %></div>
              <% if item.redeemed? %>
                <div class="text-success small">
                  <i class="bi bi-check-circle me-1"></i>Redeemed by <%= item.redeemed_by&.name || "vendor" %>
                </div>
              <% elsif pending_for_item %>
                <div class="text-warning small">
                  <i class="bi bi-hourglass-split me-1"></i>Waiting for employee approval
                </div>
              <% elsif @token.redeemable? %>
                <%# data attributes used by app_ui.js — no inline onclick needed %>
                <button class="btn btn-sm btn-outline-primary mt-1 send-redemption-btn"
                        data-item-id="<%= item.id %>"
                        data-label="<%= item.food_item.category_label %>"
                        data-url="<%= send_redemption_request_vendor_token_path(@token) %>">
                  <i class="bi bi-send me-1"></i>Request Redemption
                </button>
              <% else %>
                <div class="text-muted small">Token not redeemable</div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
