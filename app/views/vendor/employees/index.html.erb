<% content_for :title, "Employees — Vendor" %>

<div class="ft-page pb-5">
  <div class="ft-page-header px-3 py-3">
    <h2 class="ft-page-title mb-1">Employees</h2>
    <p class="text-muted small mb-0">Tokens generated for today</p>
  </div>
  <div class="px-3">
    <div class="table-responsive">
      <table class="table ft-table align-middle">
        <thead class="table-light">
          <tr><th>Employee</th><th>Meal</th><th>Token Status</th></tr>
        </thead>
        <tbody>
          <% @tokens.each do |token| %>
            <% user = token.user %>
            <tr>
              <td>
                <div class="d-flex align-items-center gap-2">
                  <div class="ft-avatar-sm"><%= user.initials %></div>
                  <div>
                    <div class="fw-semibold small"><%= user.name %></div>
                    <div class="text-muted ft-text-xs"><%= user.email %></div>
                  </div>
                </div>
              </td>
              <td class="small"><%= token.summary %></td>
              <td><%= token_status_badge(token) %></td>
            </tr>
          <% end %>
          <% if @tokens.empty? %>
            <tr><td colspan="3" class="text-center text-muted py-4">No tokens generated today.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
