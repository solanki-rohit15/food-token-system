<% content_for :title, "Change Password — CCube Food Token" %>

<div class="auth-body">
  <div class="auth-main">

    <div class="ft-auth-card">

      <!-- HEADER -->
      <div class="ft-auth-header">
        <%= image_tag "ccube_logo.webp", alt: "CCube", class: "cc-auth-logo" %>
        <h1 class="ft-auth-title">Set Your Password</h1>
        <p class="ft-auth-sub">
          Your account was created by an admin. Please set a new password to continue.
        </p>
      </div>

      <!-- FLASH / ALERT -->
      <% if alert.present? %>
        <div class="alert alert-danger alert-sm mb-3">
          <i class="bi bi-exclamation-triangle-fill me-1"></i>
          <%= alert %>
        </div>
      <% end %>

      <% if flash[:alert].present? %>
        <div class="alert alert-danger alert-sm mb-3">
          <i class="bi bi-exclamation-triangle-fill me-1"></i>
          <%= flash[:alert] %>
        </div>
      <% end %>

      <!-- FORM -->
      <%= form_tag users_change_password_path, method: :patch do %>

        <div class="mb-3">
          <label class="form-label ft-label">New Password</label>
          <input type="password"
                 name="password"
                 class="form-control ft-input"
                 placeholder="Min. 8 characters"
                 required
                 autocomplete="new-password">
        </div>

        <div class="mb-3">
          <label class="form-label ft-label">Confirm Password</label>
          <input type="password"
                 name="password_confirmation"
                 class="form-control ft-input"
                 placeholder="Repeat password"
                 required
                 autocomplete="new-password">
        </div>

        <button type="submit" class="btn cc-btn-primary w-100">
          Set Password & Continue
        </button>

      <% end %>

      <!-- FOOTER HELP -->
      <div class="ft-auth-footer mt-3">
        <p class="text-muted small mb-0">
          Make sure your password is strong and secure.
        </p>
      </div>

    </div>

  </div>
</div>