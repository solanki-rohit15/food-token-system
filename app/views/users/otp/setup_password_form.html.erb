<% content_for :title, "Set Your Password — FoodToken" %>

<div class="ft-auth-card">
  <div class="ft-auth-header">
    <div class="ft-auth-logo">🔒</div>
    <h1 class="ft-auth-title">Set Your Password</h1>
    <p class="ft-auth-sub">
      OTP verified! Create a password so you can sign in directly next time.
    </p>
  </div>

  <% if flash.now[:alert].present? || flash[:alert].present? %>
    <div class="alert alert-danger alert-sm mb-3 d-flex align-items-center gap-2">
      <i class="bi bi-exclamation-triangle-fill"></i>
      <%= flash.now[:alert] || flash[:alert] %>
    </div>
  <% end %>

  <%= form_tag users_save_password_path, method: :post do %>
    <div class="mb-3">
      <label class="form-label ft-label">New Password</label>
      <div class="input-group">
        <input type="password" name="password" id="pw-field"
               class="form-control ft-input" placeholder="Min. 6 characters" required minlength="6">
        <button class="btn btn-outline-secondary" type="button" onclick="togglePw('pw-field', this)">
          <i class="bi bi-eye"></i>
        </button>
      </div>
    </div>

    <div class="mb-4">
      <label class="form-label ft-label">Confirm Password</label>
      <div class="input-group">
        <input type="password" name="password_confirmation" id="pw-confirm"
               class="form-control ft-input" placeholder="Repeat password" required>
        <button class="btn btn-outline-secondary" type="button" onclick="togglePw('pw-confirm', this)">
          <i class="bi bi-eye"></i>
        </button>
      </div>
      <div class="form-text text-muted mt-1" id="pw-match-hint"></div>
    </div>

    <button type="submit" class="btn ft-btn-primary w-100">
      <i class="bi bi-check-circle me-2"></i>Set Password & Continue
    </button>
  <% end %>
</div>

<script>
function togglePw(id, btn) {
  const field = document.getElementById(id);
  const isText = field.type === 'text';
  field.type = isText ? 'password' : 'text';
  btn.innerHTML = isText ? '<i class="bi bi-eye"></i>' : '<i class="bi bi-eye-slash"></i>';
}

document.getElementById('pw-confirm').addEventListener('input', function() {
  const pw  = document.getElementById('pw-field').value;
  const hint = document.getElementById('pw-match-hint');
  if (this.value === '') { hint.textContent = ''; return; }
  if (this.value === pw) {
    hint.textContent = '✓ Passwords match';
    hint.className = 'form-text text-success mt-1';
  } else {
    hint.textContent = '✗ Passwords do not match';
    hint.className = 'form-text text-danger mt-1';
  }
});
</script>
